# ============================================================================
# AWS Serverless Autopost Template - Environment Configuration
# ============================================================================
# Copy this file to .env and replace YOUR_* values with real credentials.
# NEVER commit .env to version control.
# ============================================================================

# === Facebook Graph API ===
FB_PAGE_ACCESS_TOKEN=YOUR_PAGE_ACCESS_TOKEN
FB_APP_SECRET=YOUR_APP_SECRET
FB_GRAPH_API_VERSION=v23.0

# === Content Generation (LLM via OpenRouter) ===
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-4.1-mini

# === Image Generation ===
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
UNSPLASH_ACCESS_KEY=YOUR_UNSPLASH_ACCESS_KEY

# === AWS Configuration ===
AWS_REGION=YOUR_AWS_REGION              # e.g., ap-southeast-1
AWS_PROFILE=YOUR_AWS_PROFILE            # e.g., my-aws-profile

# === Project Configuration ===
PROJECT_NAME=YOUR_PROJECT_NAME          # e.g., my-autopost
TIMEZONE_OFFSET_HOURS=YOUR_UTC_OFFSET   # e.g., 8 for PHT (UTC+8)
OVERLAY_STYLE=panel                     # "panel" (1080x1080) or "gradient" (1080x1350)
WATERMARK_TEXT=YOUR_WATERMARK_TEXT       # e.g., "FB: @YourPageName"
SNS_ALARM_EMAIL=YOUR_EMAIL@example.com  # Error notification email
